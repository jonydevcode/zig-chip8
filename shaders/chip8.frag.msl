// Handwritten Metal shader, not generated by the shader build.
// Keep this in sync with the editable CHIP-8 fragment shader source.

#include <metal_stdlib>
using namespace metal;

struct VertexOut {
    float4 position [[position]];
    float2 uv;
};

fragment float4 Chip8FS(
    VertexOut in [[stage_in]],
    texture2d<float> chip8_screen [[texture(0)]],
    sampler nearest_sampler [[sampler(0)]])
{
    return chip8_screen.sample(nearest_sampler, in.uv);
}
